{
    "name": "@safari-automation/upwork-hunter",
    "version": "1.0.0",
    "description": "Autonomous Upwork proposal factory \u2014 RSS job scraping, ICP scoring, Claude AI proposal generation, Telegram approval gate",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "tsc",
        "test": "node --env-file=.env node_modules/.bin/vitest run",
